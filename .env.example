# 이 파일을 복사해서 ".env" 라는 이름으로 저장한 뒤, 발급받은 키를 채워 넣으세요.
# (README.md 에 발급 방법이 있습니다)

# 카카오 개발자 사이트의 "JavaScript 키"
KAKAO_JS_KEY=여기에_카카오_자바스크립트_키

# Google AI Studio 에서 발급받은 Gemini API 키
GEMINI_API_KEY=여기에_제미나이_키

# Gemini 모델 이름 (기본값 그대로 두면 됨)
GEMINI_MODEL=gemini-2.5-flash

# 서버 포트
PORT=3000

# 세션 암호화용 비밀 문자열 (아무 글자나 길게)
SESSION_SECRET=this-place-memory-secret-1234
